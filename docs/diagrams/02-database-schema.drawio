        </mxCell>
        <mxCell id="course_outcome" value="course_outcome (learning-map tag)&#10;PK course_outcome_id (uuid)&#10;FK course_offering_id → course_offering&#10;section_name · short_label · outcome_code&#10;body (I-can statement) · color&#10;source_kind · sort_order" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;verticalAlign=top;fontFamily=monospace" vertex="1" parent="1">
