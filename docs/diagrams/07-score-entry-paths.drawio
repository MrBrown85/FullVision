        <mxCell id="se5" style="endArrow=classic;html=1;strokeColor=#82b366" edge="1" parent="1" source="d5" target="d6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se6" style="endArrow=classic;html=1;strokeColor=#82b366" edge="1" parent="1" source="d6" target="d7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se7" style="endArrow=classic;html=1;strokeColor=#82b366" edge="1" parent="1" source="d7" target="d8"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="se8" style="endArrow=classic;html=1;strokeColor=#b85450" edge="1" parent="1" source="m1" target="m2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se9" style="endArrow=classic;html=1;strokeColor=#b85450" edge="1" parent="1" source="m2" target="m3"><mxGeometry relative="1" as="geometry" /></mxCell>
