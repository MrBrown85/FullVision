<mxfile host="app.diagrams.net" modified="2026-04-18T00:00:00.000Z" agent="fullvision" version="22.0.0">
  <diagram name="Observation Lifecycle" id="obs">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Observation Lifecycle — Create · Update · Delete" style="text;html=1;align=center;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="700" height="40" as="geometry" />
        </mxCell>

        <mxCell id="g-create" value="CREATE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="530" height="900" as="geometry" />
        </mxCell>

        <mxCell id="c1" value="Teacher enters text in capture box&#10;desktop: #capture-input&#10;mobile: #m-obs-text" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="Tag / sentiment / context choices&#10;data-action='addNewCustomTag' etc.&#10;submitOb / m-obs-save" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="240" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="addQuickOb(cid, sid, text, dims, sentiment, context, assignmentContext)&#10;[shared/data.js:4213]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="330" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="Build entry { id: 'qo_…', text, dims, sentiment, context,&#10;  assignmentContext, created: ISO, date: YYYY-MM-DD }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="all[sid].push(entry)&#10;_cache.observations[cid] = all&#10;_safeLSSet('gb-quick-obs-' + cid, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="_persistObservationCreate(cid, sid, entry)&#10;[shared/data.js:4267]&#10;Preconditions: _isUuid(cid) &amp;&amp; _isUuid(sid) &amp;&amp; sb available" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="610" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c7" value="sb.rpc('create_observation', {&#10;  p_course_offering_id: cid,&#10;  p_payload: {&#10;    enrollmentId: sid, created, sentiment,&#10;    context, text, dims&#10;  }&#10;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="60" y="710" width="490" height="130" as="geometry" />
        </mxCell>
        <mxCell id="c8" value="RPC returns row { observation_id: &lt;uuid&gt; }&#10;Patch entry.id in local cache (local id → canonical id)&#10;Persist updated LS blob" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="860" width="490" height="90" as="geometry" />
        </mxCell>

        <mxCell id="g-update" value="UPDATE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="590" y="100" width="530" height="900" as="geometry" />
        </mxCell>
        <mxCell id="u1" value="Teacher taps edit → inline edit form&#10;desktop: edit icon in obs card&#10;mobile: m-obs-edit" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="610" y="150" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u2" value="updateQuickOb(cid, sid, obId, updates)&#10;[shared/data.js:4247]&#10;updates keys: text, dims, sentiment, context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="610" y="240" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="u3" value="Mutate existing entry in _cache.observations&#10;ob.modified = new Date().toISOString()&#10;_safeLSSet('gb-quick-obs-' + cid, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="610" y="340" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="u4" value="_persistObservationUpdate(cid, ob)&#10;[shared/data.js:4302]&#10;Only proceeds if ob.id is a canonical UUID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="610" y="440" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="u5" value="sb.rpc('update_observation', {&#10;  p_observation_id: ob.id,&#10;  p_payload: { text, dims, sentiment, context }&#10;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="610" y="540" width="490" height="100" as="geometry" />
        </mxCell>
        <mxCell id="u6" value="Postgres observation.observation row UPDATE&#10;updated_at bumped by trigger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="610" y="660" width="490" height="70" as="geometry" />
        </mxCell>

        <mxCell id="g-delete" value="DELETE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="530" height="900" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="Teacher taps trash / × icon&#10;desktop: deleteOb&#10;mobile: m-obs-delete" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="1160" y="150" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="deleteQuickOb(cid, sid, obId)&#10;[shared/data.js:4235]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="1160" y="240" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="all[sid] = all[sid].filter(o =&gt; o.id !== obId)&#10;_cache.observations[cid] = all&#10;_safeLSSet('gb-quick-obs-' + cid, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="1160" y="330" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d4" value="_persistObservationDelete(cid, obId)&#10;[shared/data.js:4320]&#10;Only proceeds if obId is a UUID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="1160" y="430" width="490" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d5" value="sb.rpc('delete_observation', {&#10;  p_observation_id: obId&#10;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="1160" y="520" width="490" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d6" value="Postgres observation.observation row DELETE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left" vertex="1" parent="1">
          <mxGeometry x="1160" y="620" width="490" height="50" as="geometry" />
        </mxCell>

        <mxCell id="notes" value="Notes:&#10;• Observations are the cleanest full-CRUD canonical path in the app. This is the template for wiring goals/reflections/overrides/flags.&#10;• Before the RPC call succeeds, the in-memory ob.id is a local 'qo_…' string. After success, _persistObservationCreate patches it to the canonical UUID.&#10;• If create_observation fails, the local entry stays in cache with its local id; future edits/deletes become no-ops because _isUuid check fails." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left" vertex="1" parent="1">
          <mxGeometry x="40" y="1010" width="1630" height="80" as="geometry" />
        </mxCell>

