<mxfile host="app.diagrams.net" modified="2026-04-18T00:00:00.000Z" agent="fullvision" version="22.0.0">
  <diagram name="Service Worker" id="sw">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Service Worker — Cache Strategy &amp; Lifecycle" style="text;html=1;align=center;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="CACHE_NAME='fullvision-v35' — bumped on every deploy so installed PWAs evict stale assets." style="text;html=1;align=center;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="1100" height="30" as="geometry" />
        </mxCell>

        <mxCell id="g-life" value="Lifecycle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="740" height="560" as="geometry" />
        </mxCell>

        <mxCell id="l1" value="Browser loads HTML → script&gt; navigator.serviceWorker.register('/sw.js')" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="'install' event&#10;caches.open(CACHE_NAME) →&#10;cache.addAll(PRECACHE_URLS) →&#10;self.skipWaiting()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="PRECACHE_URLS (~30 assets)&#10;/ · /login.html · /login.css · /login-auth.js&#10;/shared/*.js · /teacher/*.{html,css,js}&#10;/teacher-mobile/*.{html,css,js}&#10;/vendor/*.js · /curriculum_data.js · /manifest.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="420" y="220" width="340" height="110" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="'activate' event&#10;caches.keys() → delete all ≠ CACHE_NAME&#10;self.clients.claim()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="360" width="340" height="100" as="geometry" />
        </mxCell>
        <mxCell id="l5" value="'message' event&#10;type='SKIP_WAITING' → self.skipWaiting()&#10;(used when a new SW is queued to take over)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="340" height="100" as="geometry" />
        </mxCell>

        <mxCell id="l6" value="Cache-bust path:&#10;1. Dev bumps CACHE_NAME in sw.js (v34 → v35)&#10;2. New deploy → new sw.js fetched&#10;3. Browser detects byte-diff, installs new SW&#10;4. 'activate' deletes old cache, claims clients&#10;5. Next navigation gets fresh assets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="700" height="150" as="geometry" />
        </mxCell>

        <mxCell id="g-fetch" value="Fetch strategy (runtime)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="820" y="100" width="840" height="1040" as="geometry" />
        </mxCell>

        <mxCell id="f1" value="fetch event for URL u, method m" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="1020" y="150" width="440" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f2" value="u.hostname contains 'supabase.co' ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="1040" y="220" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f2b" value="return — let browser handle&#10;(never cache live Supabase data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="1480" y="230" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="f3" value="method !== 'GET' ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="1040" y="320" width="400" height="70" as="geometry" />
        </mxCell>
        <mxCell id="f3b" value="return — never cache mutations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="1480" y="330" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f4" value="request.mode === 'navigate' or&#10;Accept header includes text/html ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="1040" y="410" width="400" height="80" as="geometry" />
        </mxCell>
        <mxCell id="f4b" value="HTML: network-first&#10;respondWith(&#10;  fetch(req)&#10;    .then(resp =&gt; { cache.put(req, resp.clone()); return resp })&#10;    .catch(() =&gt; caches.match(req) ||&#10;      Response('Offline — please check your connection.', 503))&#10;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="900" y="520" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="f5" value="JS / CSS / other assets: network-first&#10;respondWith(&#10;  fetch(req)&#10;    .then(resp =&gt; { cache.put(req, resp.clone()); return resp })&#10;    .catch(() =&gt; caches.match(req) || Response('', 503))&#10;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left;fontFamily=monospace" vertex="1" parent="1">
          <mxGeometry x="1360" y="520" width="280" height="150" as="geometry" />
        </mxCell>
        <mxCell id="f6" value="Net result:&#10;✓ Always tries network first → fresh JS on every load (no stale code after deploy)&#10;✓ Offline falls back to the precache so the app opens on no-network&#10;✓ Never caches Supabase or non-GET — API calls always hit the live backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="840" y="700" width="800" height="100" as="geometry" />
        </mxCell>

        <mxCell id="f-gotcha" value="Gotcha encountered earlier today:&#10;• The _doInitData stub fix was deployed but users still saw an empty dashboard because their installed PWA was serving cached old shared/data.js.&#10;• Network-first SHOULD have fetched the new version — but if the user was truly offline at install/activate, or if the browser held onto the old SW for an extra cycle, the cached copy stuck around.&#10;• Quickest user remediation: DevTools → Application → Service Workers → Unregister → hard reload.&#10;• Belt-and-braces: bump CACHE_NAME so 'activate' evicts the prior cache, forcing a fresh precache. We left v35 un-deployed to conserve Netlify credits." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left" vertex="1" parent="1">
          <mxGeometry x="840" y="820" width="800" height="200" as="geometry" />
        </mxCell>
        <mxCell id="f-manifest" value="manifest.json — display: standalone · theme_color · start_url: '/'   (controls PWA install; does not gate SW behaviour)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;align=left" vertex="1" parent="1">
          <mxGeometry x="840" y="1040" width="800" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sw1" style="endArrow=classic;html=1" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw2" style="endArrow=none;html=1;dashed=1" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw3" style="endArrow=classic;html=1" edge="1" parent="1" source="l2" target="l4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw4" style="endArrow=classic;html=1;dashed=1" edge="1" parent="1" source="l4" target="l5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw5" style="endArrow=classic;html=1" edge="1" parent="1" source="f1" target="f2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw6" value="yes" style="endArrow=classic;html=1" edge="1" parent="1" source="f2" target="f2b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw7" value="no" style="endArrow=classic;html=1" edge="1" parent="1" source="f2" target="f3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw8" value="yes" style="endArrow=classic;html=1" edge="1" parent="1" source="f3" target="f3b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw9" value="no" style="endArrow=classic;html=1" edge="1" parent="1" source="f3" target="f4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw10" value="yes" style="endArrow=classic;html=1" edge="1" parent="1" source="f4" target="f4b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw11" value="no" style="endArrow=classic;html=1" edge="1" parent="1" source="f4" target="f5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw12" style="endArrow=classic;html=1;dashed=1" edge="1" parent="1" source="f4b" target="f6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="sw13" style="endArrow=classic;html=1;dashed=1" edge="1" parent="1" source="f5" target="f6"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
